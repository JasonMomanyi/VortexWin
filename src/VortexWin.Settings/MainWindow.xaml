<ui:FluentWindow x:Class="VortexWin.Settings.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Vortex Win - Settings" Height="600" Width="900" 
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vortex Win" />

        <ui:NavigationView Grid.Row="1" x:Name="RootNavigation" PaneDisplayMode="Left">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard" Icon="{ui:SymbolIcon Home24}" Tag="dashboard" />
                <ui:NavigationViewItem Content="Timer" Icon="{ui:SymbolIcon Timer24}" Tag="timer" />
                <ui:NavigationViewItem Content="Sentinel Folder" Icon="{ui:SymbolIcon Folder24}" Tag="folder" />
                <ui:NavigationViewItem Content="Alerts" Icon="{ui:SymbolIcon Alert24}" Tag="alerts" />
                <ui:NavigationViewItem Content="Security" Icon="{ui:SymbolIcon LockShield24}" Tag="security" />
                <ui:NavigationViewItem Content="Recovery" Icon="{ui:SymbolIcon Key24}" Tag="recovery" />
                <ui:NavigationViewItem Content="Advanced" Icon="{ui:SymbolIcon Settings24}" Tag="advanced" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Logs" Icon="{ui:SymbolIcon DocumentText24}" Tag="logs" />
                <ui:NavigationViewItem Content="Appearance" Icon="{ui:SymbolIcon Color24}" Tag="appearance" />
                <ui:NavigationViewItem Content="About" Icon="{ui:SymbolIcon Info28}" Tag="about" />
            </ui:NavigationView.FooterMenuItems>

            <ui:NavigationView.ContentOverlay>
                <Grid x:Name="ContentGrid" Margin="20">
                    <StackPanel x:Name="DashboardPanel" Visibility="Visible">
                        <TextBlock Text="Dashboard" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20" />
                        <ui:CardControl Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="ShieldCheckmark24" Grid.Column="0" FontSize="32" Foreground="LightGreen" Margin="0,0,15,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="System Status" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtStatus" Text="Connecting to service..." Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                        </ui:CardControl>
                        
                        <ui:CardControl>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="Timer24" Grid.Column="0" FontSize="32" Foreground="Goldenrod" Margin="0,0,15,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Countdown Engine" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtCountdown" Text="Idling" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                        </ui:CardControl>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <ui:Button x:Name="btnRefresh" Content="Refresh Status" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Primary" Click="BtnRefresh_Click" Margin="0,0,10,0"/>
                            <ui:Button x:Name="btnTest" Content="Test Challenge" Icon="{ui:SymbolIcon Play24}" Appearance="Danger" Click="BtnTest_Click"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel x:Name="PlaceholderPanel" Visibility="Collapsed">
                        <TextBlock x:Name="txtPlaceholder" Text="Placeholder" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
